smtp:
  host: smtp.qq.com
  port: 587
  mode: starttls
  username: your@qq.com
  password: your_qq_mail_auth_code
  from: your@qq.com
  to: your@qq.com

mail:
  subject: "Codex 任务完成"
  maxMessageLength: 800
  includeEmptyReply: false

session:
  titleLookup: true
  indexPath: ""
  maxTitleLength: 80

attachment:
  enabled: true
  mode: when_truncated
  filenamePrefix: codex-reply
  maxBytes: 2097152

dedup:
  enabled: true
  windowSeconds: 30

log:
  path: notify-mail.log
